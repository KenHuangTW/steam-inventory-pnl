{
  "compilerOptions": {
    "target": "ES2022",
    "module": "none",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist/scripts",
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
